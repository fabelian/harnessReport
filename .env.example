# Root-level env reference.
# Actual values live in `backend/.env` (see `backend/.env.example`)
# and `frontend/.env.local` (see `frontend/.env.local.example`).
# Keep this file as a quick overview of all keys used by the project.

# --- Backend (required) ---
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_DEFAULT_MODEL=openai/gpt-oss-120b

# --- Backend (optional, Phase 1+) ---
# FRED_API_KEY=
# NEWS_API_KEY=
# TAVILY_API_KEY=

# --- Frontend (optional) ---
# NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
