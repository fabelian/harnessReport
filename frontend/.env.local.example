# Backend URL used by next.config.mjs rewrites.
# Required in production (NODE_ENV=production); the rewrite will throw on boot if unset.
#
# Local dev (default):
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
#
# Railway — public backend URL:
#   NEXT_PUBLIC_BACKEND_URL=https://<backend-service>.up.railway.app
#
# Railway — private network (recommended; no public egress, no TLS overhead).
# Replace `backend` with your backend service name and the port it listens on
# (Railway injects $PORT into the backend; align this value with it):
#   NEXT_PUBLIC_BACKEND_URL=http://${{backend.RAILWAY_PRIVATE_DOMAIN}}:8080
