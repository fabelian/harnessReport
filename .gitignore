# User-local Claude Code settings (per-machine, not shared)
.claude/settings.local.json

# Oh-My-ClaudeCode runtime state (match at any nesting depth)
**/.omc/state/
**/.omc/

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/

# Secrets
.env
.env.local
.env.*.local
!.env.example
!.env.local.example

# --- Python (backend) ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# SQLite databases
*.db
*.db-journal
*.sqlite
*.sqlite3

# --- Node / Next.js (frontend) ---
node_modules/
.next/
out/
dist/
build/
next-env.d.ts
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.*

# Logs
*.log
