# OpenRouter — required
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-oss-120b

# FRED (macro data) — required for macro agent (Phase 6), optional for MVP
FRED_API_KEY=

# News API — choose one (or leave both empty to use RSS fallback)
NEWS_API_KEY=
TAVILY_API_KEY=

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000

# Storage
DATABASE_URL=sqlite+aiosqlite:///./jobs.db

# Misc
LOG_LEVEL=INFO
